{
  "name": "eslint-plugin-anvil",
  "version": "1.0.0",
  "description": "Custom ESLint rules for TypeScript type hygiene",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fhwang/eslint-plugin-anvil.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "pnpm run build && eslint .",
    "typecheck": "tsc --noEmit",
    "check-types": "forbid-junk-object-types --target-dir .",
    "prepublishOnly": "pnpm run build && pnpm test"
  },
  "packageManager": "pnpm@10.19.0",
  "dependencies": {
    "@typescript-eslint/utils": "^8.44.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@typescript-eslint/rule-tester": "^8.44.0",
    "eslint": "^9.39.2",
    "forbid-junk-object-types": "^1.4.0",
    "globals": "^17.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.1.6"
  }
}
